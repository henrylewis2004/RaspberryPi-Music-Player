; generated by claude (T_T)
; i2s.pio
; 16-bit stereo I2S output for TLV320DAC3100 ;
; side-set 2 pins: bit1 = BCLK, bit0 = LRCLK
; out pin: DATA
; ; DMA feeds 32-bit words: upper 16 = left sample, lower 16 = right sample
; OSR shifts left -> MSB first
; Autopull at 32 bits

.program i2s_out 
.side_set 2


.wrap_target

	; left channel (LRCLK = 0)
	set x, 14	side 0b00 ; LRCLK low, BCLK low, loop counter
lloop:
	out pins, 1	side 0b00 ; data bit out, BCLK low (data setup)
	jmp x-- lloop	side 0b01 ; BCLK high -> DAC samples bit, decrement
	out pins, 1 	side 0b00 ; 16th left bit, BCLK low
	nop		side 0b01 ; BCLK high -> DAC samples last left bit

	; right channel (LRCLK = 1)
	set x, 14	side 0b10 ; data bit out, BCLK low
rloop:
	out pins, 1	side 0b10 ; data bit out, BCLK low
	jmp x-- rloop	side 0b11 ; BCLK high -> DAC samples bit, decrement
	out pins, 1	side 0b10 ; 16th right bit, BCLK low
	nop		side 0b11 ; BCLK high -> DAC samples last right bit

.wrap

% c-sdk {

#include "hardware/gpio.h"
#include "hardware/pio.h"
#include "hardware/clocks.h"
#include "audio_dac_pin_values.h"

static inline void i2s_out_program_init(PIO pio, uint sm, uint offset, uint32_t sample_rate){

	pio_gpio_init(pio,DAC_DIN_GPIO_PIN);
	pio_gpio_init(pio,DAC_BCK_GPIO_PIN);
	pio_gpio_init(pio,DAC_WSEL_GPIO_PIN); //note has to be wired directly after the BCLK pin

	pio_sm_set_consecutive_pindirs(pio,sm,DAC_DIN_GPIO_PIN,1,true);
	pio_sm_set_consecutive_pindirs(pio,sm,DAC_BCK_GPIO_PIN,2,true);

	pio_sm_config pio_cfg = i2s_out_program_get_default_config(offset);

	sm_config_set_out_pins(&pio_cfg, DAC_DIN_GPIO_PIN, 1);
	sm_config_set_sideset_pins(&pio_cfg,DAC_BCK_GPIO_PIN);

	// shift left (MSB first) autopull when 32 bits shifted out
	sm_config_set_out_shift(&pio_cfg,false,true,32);

	//FIFO join TX for deeper buffer
	sm_config_set_fifo_join(&pio_cfg,PIO_FIFO_JOIN_TX);

	// clock divider: 2 PIO cycles per BCLK edge, 32 BCLK per stereo frame
	// + 2 overhead cycles per channel (set x instructions)
	float div = (float)clock_get_hz(clk_sys) / (sample_rate * 66.0f);
	sm_config_set_clkdiv(&pio_cfg,div);

	pio_sm_init(pio,sm,offset,&pio_cfg);
	pio_sm_set_enabled(pio,sm,true);
}

%}

